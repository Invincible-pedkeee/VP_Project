<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<appSettings>
		<add key="RowLimitN" value="100"/>
		<add key="CsvFilePath" value="Data\Floating_PV_Altamonte_FL_Data.csv"/>
		<add key="PlantId" value="AltamonteFL"/>
		<add key="SchemaVersion" value="1.0"/>
		<add key="RejectedLogPath" value="rejected_client.csv"/>
	</appSettings>

	<system.serviceModel>
		<client>
			<endpoint
			  name="SolarPanelEndpoint"
			  address="net.tcp://localhost:9000/SolarPanel"
			  binding="netTcpBinding"
			  bindingConfiguration="streamingBinding"
			  contract="Common.ISolarPanelService"/>
		</client>

		<bindings>
			<netTcpBinding>
				<binding name="streamingBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 receiveTimeout="00:10:00"
						 sendTimeout="00:10:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"/>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
	
</configuration>